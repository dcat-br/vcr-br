    <dct:title xml:lang="pt-BR">Vocabulário Controlado — Objetivos de Desenvolvimento Sustentável (ODS)</dct:title>
    <dct:title xml:lang="en">Controlled Vocabulary — Sustainable Development Goals (SDGs)</dct:title>
    <dct:description xml:lang="pt-BR">Vocabulário controlado para indicar a relação de conjuntos de dados com os Objetivos de Desenvolvimento Sustentável da Agenda 2030 no perfil DCAT-BR.</dct:description>
    <dct:description xml:lang="en">Controlled vocabulary to indicate the relationship of datasets with the Sustainable Development Goals of the 2030 Agenda in the DCAT-BR profile.</dct:description>
    <dct:source rdf:resource="https://sdgs.un.org/goals"/>
    <dct:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2025-12-12</dct:issued>
    <owl:versionInfo>1.0.0</owl:versionInfo>
