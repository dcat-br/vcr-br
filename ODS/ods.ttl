@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .

@prefix ods: <https://dcat-br.github.io/vcr-br/ods/> .

#######################################################################
# ODS — Objetivos de Desenvolvimento Sustentável (DCAT-BR)
#######################################################################

<https://dcat-br.github.io/vcr-br/ods/>
  a owl:Ontology, skos:ConceptScheme ;
  dct:title "Vocabulário Controlado — Objetivos de Desenvolvimento Sustentável (ODS)"@pt-BR ;
  dct:title "Controlled Vocabulary — Sustainable Development Goals (SDGs)"@en ;
  dct:description "Vocabulário controlado para indicar a relação de conjuntos de dados com os Objetivos de Desenvolvimento Sustentável da Agenda 2030 no perfil DCAT-BR."@pt-BR ;
  dct:description "Controlled vocabulary to indicate the relationship of datasets with the Sustainable Development Goals of the 2030 Agenda in the DCAT-BR profile."@en ;
  dct:source <https://sdgs.un.org/goals> ;
  dct:issued "2025-12-12"^^xsd:date ;
  owl:versionInfo "1.0.0" ;
  skos:hasTopConcept
    ods:erradicacao_da_pobreza,
    ods:fome_zero_e_agricultura_sustentavel,
    ods:saude_e_bem-estar,
    ods:educacao_de_qualidade,
    ods:igualdade_de_genero,
    ods:agua_limpa_e_saneamento,
    ods:energia_limpa_e_acessivel,
    ods:trabalho_decente_e_crescimento_economico,
    ods:industria_inovacao_e_infraestrutura,
    ods:reducao_das_desigualdades,
    ods:cidades_e_comunidades_sustentaveis,
    ods:consumo_e_producao_sustentaveis,
    ods:acao_contra_a_mudanca_global_do_clima,
    ods:vida_na_agua,
    ods:vida_terrestre,
    ods:paz_justica_e_instituicoes_eficazes,
    ods:parcerias_e_meios_de_implementacao ;
.

#######################################################################
# Termos (URIs DCAT-BR) + mapeamento (skos:exactMatch) para ODS ONU
#######################################################################

ods:erradicacao_da_pobreza
  a skos:Concept ;
  skos:inScheme <https://dcat-br.github.io/vcr-br/ods/> ;
  skos:topConceptOf <https://dcat-br.github.io/vcr-br/ods/> ;
  skos:notation "1" ;
  skos:prefLabel "Erradicação da Pobreza"@pt-BR ;
  skos:prefLabel "No poverty"@en ;
  skos:exactMatch <http://metadata.un.org/sdg/1> ;
.

