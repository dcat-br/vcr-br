 .

<http://id.loc.gov/vocabulary/iso639-1/it>
  a skos:Concept ;
  skos:inScheme vcr-ln: ;
  skos:topConceptOf vcr-ln: ;
  skos:notation "it" ;
  dc:identifier "it" ;
  skos:prefLabel "Italiano"@pt-BR, "Italian"@en ;
  skos:definition "Linguagem italiana conforme código ISO 639-1."@pt-BR, "Italian language according to ISO 639-1 code."@en ;
  skos:exactMatch <http://id.loc.gov/vocabulary/iso639-2/ita>, <http://id.loc.gov/vocabulary/languages/ita> ;
